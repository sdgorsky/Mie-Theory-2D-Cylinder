#!/bin/bash

# Pre-commit hook for 2D-Scattering
# Enforces linting and formatting for Rust and TypeScript

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

echo "Running pre-commit checks..."

# Get the root of the git repo
REPO_ROOT=$(git rev-parse --show-toplevel)

# Track if any checks fail
FAILED=0

# ============================================
# Rust Checks
# ============================================

echo ""
echo -e "${YELLOW}Checking Rust...${NC}"

echo "  Checking rustfmt..."
if ! (cd "$REPO_ROOT/scattering-core" && cargo fmt --check 2>/dev/null); then
    echo -e "${RED}  ✗ Rust formatting check failed${NC}"
    echo "  Run 'cd scattering-core && cargo fmt' to fix formatting"
    FAILED=1
else
    echo -e "${GREEN}  ✓ Rust formatting OK${NC}"
fi

echo "  Running clippy..."
if ! (cd "$REPO_ROOT/scattering-core" && cargo clippy -- -D warnings 2>/dev/null); then
    echo -e "${RED}  ✗ Clippy found issues${NC}"
    echo "  Fix the issues reported above before committing"
    FAILED=1
else
    echo -e "${GREEN}  ✓ Clippy OK${NC}"
fi

echo "  Running Rust tests..."
if ! (cd "$REPO_ROOT/scattering-core" && cargo test --quiet 2>/dev/null); then
    echo -e "${RED}  ✗ Rust tests failed${NC}"
    echo "  Run 'make test' for detailed output"
    FAILED=1
else
    echo -e "${GREEN}  ✓ Rust tests OK${NC}"
fi

# ============================================
# TypeScript/JavaScript Checks
# ============================================

echo ""
echo -e "${YELLOW}Checking TypeScript...${NC}"

if [ ! -d "$REPO_ROOT/node_modules" ]; then
    echo -e "${YELLOW}  Installing npm dependencies...${NC}"
    (cd "$REPO_ROOT" && npm install --silent)
fi

echo "  Checking Prettier formatting..."
if ! (cd "$REPO_ROOT" && npm run format:check --silent 2>/dev/null); then
    echo -e "${RED}  ✗ TypeScript formatting check failed${NC}"
    echo "  Run 'npm run format' to fix formatting"
    FAILED=1
else
    echo -e "${GREEN}  ✓ TypeScript formatting OK${NC}"
fi

echo "  Running ESLint..."
if ! (cd "$REPO_ROOT" && npm run lint --silent 2>/dev/null); then
    echo -e "${RED}  ✗ ESLint found issues${NC}"
    echo "  Fix the issues reported above before committing"
    FAILED=1
else
    echo -e "${GREEN}  ✓ ESLint OK${NC}"
fi

# ============================================
# Final Result
# ============================================

echo ""
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}Pre-commit checks failed!${NC}"
    echo "Please fix the issues above and try again."
    echo "To bypass this check (not recommended), use: git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}All pre-commit checks passed!${NC}"
    exit 0
fi
